{
  "name": "skill-decay",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "11",
      "jdkDistro": "ms"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "forwardPorts": [8080, 8501, 5000],
  "portsAttributes": {
    "8080": { "label": "Airflow UI" },
    "8501": { "label": "Streamlit" },
    "5000": { "label": "MLflow" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "eamodio.gitlens",
        "redhat.vscode-yaml"
      ]
    }
  },

  "remoteUser": "codespace"
}